# Normalize text files to LF in the repo and on checkout
* text=auto eol=lf

# Windows-only scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binaries — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.icns binary
*.svg text eol=lf
*.pdf binary
*.zip binary
*.gz binary
*.tgz binary
*.jar binary
*.keystore binary
*.jks binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.mp3 binary
*.mp4 binary
*.wav binary
*.mov binary
